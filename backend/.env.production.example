# ─────────────────────────────────────────────────────────────────────────────
# Align backend — PRODUCTION environment template.
# Copy to your host's secret manager (Render / Railway / AWS). Never commit real
# values. Generate JWT_SECRET with:  openssl rand -base64 48
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# Database (Supabase or Neon).
# IMPORTANT: use the POOLED connection string for the app (PgBouncer, port 6543
# on Supabase) and append connection_limit + pgbouncer flags for Prisma.
#   Supabase: ...pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   Neon:     ...neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Direct (non-pooled) URL used ONLY for migrations (Supabase port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Auth
JWT_SECRET=replace-with-openssl-rand-base64-48
JWT_EXPIRES_IN=7d

# CORS / allowed origins (comma separated): admin panel + app web build.
CLIENT_URL=https://admin.yourdomain.com,https://app.yourdomain.com

# Redis — enables the Socket.IO adapter for horizontal scaling.
# Leave blank for a single instance; set for 2+ replicas.
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (subscriptions)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# OTP — MUST be false in production so codes are sent via SMS, not logged.
OTP_DEV_MODE=false
