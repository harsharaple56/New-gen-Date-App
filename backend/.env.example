# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/align?schema=public"
# Direct (non-pooled) URL for migrations. Same as DATABASE_URL locally; in prod
# set to the direct Postgres port when DATABASE_URL points at a PgBouncer pool.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/align?schema=public"

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend / CORS (comma separated for multiple origins)
CLIENT_URL=http://localhost:5173,http://localhost:19006,exp://127.0.0.1:19000

# Cloudinary (image upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (subscriptions)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# OTP (dev mode logs the OTP to console instead of sending SMS)
OTP_DEV_MODE=true
